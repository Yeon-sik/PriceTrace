{
  "name": "receipt-settlement-mvp",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:android:web": "set CAPACITOR_BUILD=true&& next build",
    "android:sync": "npm run build:android:web && npx cap sync android",
    "android:open": "npx cap open android",
    "android:debug": "npm run android:sync && cd android && gradlew.bat assembleDebug",
    "start": "next start",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/cli": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.50.0",
    "next": "15.3.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "zod": "3.24.3",
    "zustand": "5.0.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.1",
    "@playwright/test": "1.52.0",
    "@types/node": "22.15.2",
    "@types/react": "19.1.2",
    "@types/react-dom": "19.1.2",
    "eslint": "9.25.0",
    "eslint-config-next": "15.3.0",
    "supabase": "^2.109.1",
    "typescript": "5.8.3",
    "vitest": "3.1.2"
  }
}
